# =============================================================
# IMAM TRAVELS — EmailJS Configuration Reference
# =============================================================
#
# Angular doesn't load .env files at runtime — these values
# must be placed in:
#   src/environments/environment.ts            (dev)
#   src/environments/environment.production.ts (prod)
#
# This file is purely a CHECKLIST so you know what to fetch
# from your EmailJS dashboard.
#
# All values are PUBLIC by design — EmailJS rate-limits and
# restricts by allowed origins (configure in dashboard).
# =============================================================

# From: https://dashboard.emailjs.com/admin/account
EMAILJS_PUBLIC_KEY=

# From: https://dashboard.emailjs.com/admin → Email Services
EMAILJS_SERVICE_ID=

# From: https://dashboard.emailjs.com/admin/templates
# Template 1: Contact form (variables: from_name, from_email, phone, service, message)
EMAILJS_CONTACT_TEMPLATE_ID=

# Template 2: Hajj 2026 registration (variables: from_name, from_email, phone, dob,
#   passport, passport_expiry, package, departure_city, travellers, requirements, contact_method)
EMAILJS_HAJJ_TEMPLATE_ID=
